<!DOCTYPE html>
<html lang="ar">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>منصة RevoAI</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <!-- الهيدر -->
  <header>
    <div class="logo">
      <img src="logo.png" alt="RevoAI" style="height:60px;">
      <span>RevoAI</span>
    </div>
    <nav>
      <a href="#features">المميزات</a>
      <a href="#demo">جرّب الآن</a>
      <a href="#contact">تواصل معنا</a>
    </nav>
  </header>

  <!-- قسم البطل -->
  <section class="hero">
    <h1>منصة RevoAI</h1>
    <p>حوّل النصوص والصور إلى فيديوهات عالية الجودة بالذكاء الاصطناعي.</p>
    <a href="#demo" class="btn">ابدأ الآن</a>
  </section>

  <!-- قسم المميزات -->
  <section id="features">
    <h2>المميزات</h2>
    <ul>
      <li>تحويل صورة + نص إلى فيديو</li>
      <li>جودة عالية مثل Higgsfield</li>
      <li>واجهة سهلة الاستخدام</li>
      <li>دعم الدفع بالكريبتو عبر NOWPayments</li>
    </ul>
  </section>

  <!-- قسم التجربة -->
  <section id="demo">
    <h2>جرّب المنصة</h2>
    <p>ارفع صورة واكتب نصك، وخلي RevoAI يولّد الفيديو.</p>
    <form>
      <input type="file" accept="image/*">
      <textarea placeholder="اكتب النص هنا..."></textarea>
      <button type="submit">توليد الفيديو</button>
    </form>
  </section>

  <!-- قسم التواصل -->
  <section id="contact">
    <h2>تواصل معنا</h2>
    <p>تابعنا على تيك توك وإنستغرام لمحتوى ترند جديد.</p>
    <a href="https://tiktok.com/@revoai" target="_blank">TikTok</a>
    <a href="https://instagram.com/revoai" target="_blank">Instagram</a>
  </section>

  <!-- الفوتر -->
  <footer>
    <p>© 2026 RevoAI — جميع الحقوق محفوظة</p>
  </footer>

</body>
</html>
