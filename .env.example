# البورت
PORT=4000
MODE_ENV=development
FRONTEND_URL=http://localhost:3000

# قاعدة البيانات
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_video_platform?schema=public"

# JWT
JWT_ACCESS_SECRET=اكتب_سلسلة_طويلة_عشوائية_هنا
JWT_ACCESS_EXPIRES_IN=15
JWT_REFRESH_SECRET=اكتب_سلسلة_طويلة_عشوائية_مختلفة_هنا
JWT_REFRESH_EXPIRES_IN=7

# مصادقة جوجل
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# البريد الإلكتروني
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="YourPlatform <noreply@yourplatform.com>"

# Cloudflare R2 (تخزين S3)
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# المعاملات
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_SECRET=
USDT_TRC20=
USDT_BEP20=
